<?xml version="1.0" encoding="utf-8"?>
<!--
    ECRAN 6 : Modification d'une note
    IDs alignés sur EditNoteActivity.java (Membre 5)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="Modifier la note"
            app:titleTextColor="#000000"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="#000000" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenu principal : formulaire + palette de couleurs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Titre - Titre 3 : 24px, bold -->
                <EditText
                    android:id="@+id/etTitre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Titre"
                    android:textColorHint="#80000000"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:inputType="textCapSentences"
                    android:maxLines="2" />

                <!-- Contenu - Text 1 : 14px, normal -->
                <EditText
                    android:id="@+id/etContenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@android:color/transparent"
                    android:hint="Contenu"
                    android:textColorHint="#80000000"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:gravity="top"
                    android:minLines="10"
                    android:inputType="textMultiLine|textCapSentences" />

            </LinearLayout>
        </ScrollView>

        <!-- Sélecteur de couleurs : rangée fixe de 6 bulles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="16dp">

            <View
                android:id="@+id/btnColorVert"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/circle_color_vert"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/btnColorRouge"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/circle_color_rouge"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/btnColorBleu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/circle_color_bleu"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/btnColorJaune"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/circle_color_jaune"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/btnColorOrange"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/circle_color_orange"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/btnColorGris"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/circle_color_gris"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- FAB Save -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Enregistrer la note"
        android:src="@drawable/ic_save"
        app:tint="#FFFFFF"
        app:backgroundTint="#000000" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
